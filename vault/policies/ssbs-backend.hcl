# Vault Policy — Backend Application
# Grants read-only access to all SSBS secrets
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

path "secret/data/ssbs/*" {
  capabilities = ["read", "list"]
}

path "secret/metadata/ssbs/*" {
  capabilities = ["read", "list"]
}
