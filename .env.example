# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SSBS Environment Configuration (Example)
# Copy this file to .env and fill in your values
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Database (PostgreSQL)
POSTGRES_DB=ssbs_db
POSTGRES_USER=ssbs_user
POSTGRES_PASSWORD=changeme
DB_HOST=db
DB_PORT=5432

# Backend (Django)
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=True

# 42 Intra OAuth
INTRA_42_CLIENT_ID=your-client-id
INTRA_42_CLIENT_SECRET=your-client-secret
INTRA_42_REDIRECT_URI=http://localhost:8000/api/v1/auth/42/callback/

# Admin user (42 login that gets LOGISTICS_STAFF role)
ADMIN_42_LOGIN=your-42-login

# Frontend (Vite)
VITE_API_URL=http://localhost:8000/api
