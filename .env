# Legacy key used in some scripts
OAUTH_42_REDIRECT_URI=https://localhost:8443/api/v1/auth/42/callback/

# Admin user (42 login that gets LOGISTICS_STAFF role)
ADMIN_42_LOGIN=mlahrach

# ──────────────────────────────────────
# Frontend (Vite)
# ──────────────────────────────────────

FRONTEND_URL=https://localhost:8443
VITE_API_URL=/api/v1

# ──────────────────────────────────────
# Infrastructure (ELK, Vault, WAF)
# ──────────────────────────────────────
VAULT_ADDR=http://vault:8200
LOG_LEVEL=debug
CORS_ALLOWED_ORIGINS=https://localhost:8443,http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# AppRole credentials (populated by vault-init)
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=

# Docker
COMPOSE_PROJECT_NAME=ssbs
 

